# API configuration
GOOGLE_API_KEY=AIzaSy...your-gemini-key
GROQ_API_KEY=gsk_...your-groq-key
INGESTION_MODEL_NAME=gemini-2.5-flash
CHAT_MODEL_NAME=llama-3.3-70b-versatile

# Vector DB (Qdrant Cloud)
QDRANT_URL=https://your-qdrant-cluster.aws.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=legal_docs

# Database (Local SQLite)
SQLITE_DB_PATH=storage/legal_data.db

# App Settings
DEBUG=True
